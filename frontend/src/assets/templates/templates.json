    {
      "id": "ATT-CND-THRESHOLD-001",
      "type": "default",
      "category": "Certified threshold response",
      "modality": "Condition",
      "communicative_function": "Threshold-triggered action confirmed",
      "representative_example": "If the pH fell below 4.2, the batch was discarded.",
      "structural_template": "If <Parameter> *[exceeded/fell below] *<Limit>, *<VerifiedAction>.",
      "components": {
        "1": {
          "label": "Parameter",
          "text": "the pH",
          "required": true,
          "description": "Measured parameter that triggered the verified action.",
          "examples": [
            "the pH",
            "the temperature",
            "the histamine level"
          ],
          "allow_custom": true
        },
        "2": {
          "label": "Limit",
          "text": "4.2",
          "required": true,
          "description": "Numeric threshold that triggered the action (value + optional unit).",
          "examples": [
            "4.2",
            "5°C",
            "20 mg/kg"
          ],
          "allow_custom": true
        },
        "3": {
          "label": "VerifiedAction",
          "text": "the batch was discarded",
          "required": true,
          "description": "Action certified as taken when the threshold was crossed.",
          "examples": [
            "the batch was discarded",
            "the lot was rejected",
            "production was stopped"
          ],
          "allow_custom": true
        }
      }
    },
