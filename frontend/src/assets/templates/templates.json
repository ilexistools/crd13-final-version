    {
      "id": "ATT-CND-RISK-CONTROL-001",
      "type": "default",
      "category": "Certified risk control",
      "modality": "Condition",
      "communicative_function": "Risk control confirmed",
      "representative_example": "Micro-organisms that may present a health risk have been eliminated.",
      "structural_template": "*<CertifiedSubject> *[that/which may] *<RiskVerbPhrase> has/have been *<VerifiedAction>.",
      "components": {
        "1": {
          "label": "CertifiedSubject",
          "text": "Micro-organisms",
          "required": true,
          "description": "Entity or agents certified as potentially presenting a risk.",
          "examples": [
            "Micro-organisms",
            "Contaminants",
            "Pathogenic bacteria"
          ],
          "allow_custom": true
        },
        "2": {
          "label": "RiskVerbPhrase",
          "text": "present a health risk",
          "required": true,
          "description": "Verb phrase expressing the potential or conditional risk that was controlled.",
          "examples": [
            "present a health risk",
            "pose a risk to consumers",
            "cause contamination"
          ],
          "allow_custom": true
        },
        "3": {
          "label": "VerifiedAction",
          "text": "eliminated",
          "required": true,
          "description": "Verified action or state showing that the identified risk was mitigated or eliminated.",
          "examples": [
            "eliminated",
            "controlled",
            "removed from the process"
          ],
          "allow_custom": true
        }
      }
    },
