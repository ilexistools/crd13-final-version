{
  "doc_id": "2e8611e9-da91-41c9-a542-c5b70835fbfd",
  "title": "1 introduction",
  "sections": [
    {
      "section_id": 1,
      "order": 0,
      "section": "1 introduction",
      "summary": "States that this document should be read in conjunction with the Guidelines for the Design, Production, Issuance and Use of Generic Official Certificates (CAC/GL 38-2001).",
      "categories": [
        "other",
        "documentation"
      ],
      "subcategories": [
        "introduction heading",
        "reference guidance"
      ],
      "page_range": {
        "start_page": 1,
        "end_page": 1
      }
    },
    {
      "section_id": 2,
      "order": 1,
      "section": "2 scope",
      "summary": "Defines the Model Export Certificate for Milk and Milk Products as applying to milk, milk products and composite milk products (per CODEX STAN 206-1999) presented for international trade that meet food safety and suitability requirements, and excludes animal and plant health matters unless directly related to food safety or suitability (referring to the OIE Code when animal health attestations are needed).",
      "categories": [
        "scope"
      ],
      "subcategories": [
        "scope heading",
        "applicability"
      ],
      "page_range": {
        "start_page": 1,
        "end_page": 1
      }
    },
    {
      "section_id": 3,
      "order": 2,
      "section": "3 explanatorY notes on tHe model export certificate for milk and milk products",
      "summary": "Heading only: introductory/explanatory notes on the model export certificate for milk and milk products (no substantive text in this section).",
      "categories": [
        "other"
      ],
      "subcategories": [
        "notes heading"
      ],
      "page_range": {
        "start_page": 1,
        "end_page": 1
      }
    },
    {
      "section_id": 4,
      "order": 3,
      "section": "4 general",
      "summary": "Provides general completion and presentation instructions for the certificate, requiring legible completion and page numbering to show all pages form a single certificate; it also states that changes to destination, consignee, point of entry or transport after issuance must be advised to the importing country's competent authority and should not require issuance of a replacement certificate.",
      "categories": [
        "other",
        "documentation",
        "inspection certification"
      ],
      "subcategories": [
        "general heading",
        "completion instructions",
        "page numbering",
        "certificate amendment",
        "reference numbering"
      ],
      "page_range": {
        "start_page": 1,
        "end_page": 1
      }
    },
    {
      "section_id": 5,
      "order": 4,
      "section": "5 MODEL EXPORT CERTIFICATE FOR MILK AND MILK PRODUCTS",
      "summary": "Specifies the fields, definitions and information required on the Model Export Certificate for Milk and Milk Products—such as certificate type and unique number, consignor/consignee, competent authority, country of dispatch/origin/destination, transport and entry points, quantities, container and package identification, product identification (including nature of food, HS code, intended purpose, lot identifier, production dates, approval numbers, region of origin), and an attestation confirming regulatory standing, processing under HACCP where appropriate, and hygiene compliance—plus certifying officer name, position, signature and date.",
      "categories": [
        "inspection certification",
        "documentation",
        "other",
        "transport",
        "weights and measures",
        "packaging",
        "composition",
        "labelling"
      ],
