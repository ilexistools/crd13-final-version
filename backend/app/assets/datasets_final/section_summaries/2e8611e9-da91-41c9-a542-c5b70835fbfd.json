    {
      "section_id": 49,
      "order": 48,
      "section": "16. Attestations:",
      "summary": "Requires attestation that the products were manufactured at establishment(s) approved by, or in good regulatory standing with, the exporting country's competent authority. It also requires ticking applicable attestations that products were prepared, packed, held and transported under good hygienic practice and an effective food safety control system (within HACCP context where appropriate and in accordance with CAC/RCP 57-2004), and/or that they were produced in accordance with the public health requirements of a specified country, with non-selected options deletable.",
      "categories": [
        "inspection certification"
      ],
      "subcategories": [
        "attestations heading",
        "establishment approval",
        "product attestations",
        "hygiene attestation",
        "public health compliance"
      ],
